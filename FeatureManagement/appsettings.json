{
  "FeatureManagement": {

    "NewCheckoutFlow": {
      "EnabledFor": [
        {
          "Name": "GradualRollout",
          "Parameters": {
            "Percentage": 25,
            "Salt": "checkout-v2"
          }
        }
      ]
    },

    "OneClickCheckout": {
      "EnabledFor": [
        {
          "Name": "Targeting",
          "Parameters": {
            "Audience": {
              "Users": [ "alice@example.com", "bob@example.com" ],
              "Groups": [
                {
                  "Name": "BetaTester",
                  "RolloutPercentage": 100
                },
                {
                  "Name": "Admin",
                  "RolloutPercentage": 100
                }
              ],
              "DefaultRolloutPercentage": 0
            }
          }
        }
      ]
    },

    "BuyNowPayLater": {
      "EnabledFor": [
        {
          "Name": "Tenant",
          "Parameters": { "AllowedTenants": [ "tenant-acme", "tenant-globex" ] }
        }
      ]
    },

    "NewRecommendationEngine": {
      "EnabledFor": [
        {
          "Name": "GradualRollout",
          "Parameters": {
            "Percentage": 10,
            "Salt": "reco-v2"
          }
        }
      ]
    },

    "SemanticSearch": {
      "EnabledFor": [
        {
          "Name": "UserRole",
          "Parameters": { "Roles": [ "BetaTester", "Admin" ] }
        }
      ]
    },

    "BetaDashboard": {
      "EnabledFor": [
        {
          "Name": "TimeWindow",
          "Parameters": {
            "Start": "2025-04-01T00:00:00Z",
            "End": "2025-06-30T00:00:00Z"
          }
        },
        {
          "Name": "UserRole",
          "Parameters": { "Roles": [ "Admin" ] }
        }
      ]
    },

    "ReadReplicaRouting": true,

    "HybridCacheEnabled": {
      "EnabledFor": [
        {
          "Name": "Environment",
          "Parameters": { "Environments": [ "Development", "Staging" ] }
        }
      ]
    },

    "DisableEmailSending": false,

    "MaintenanceMode": false

  }
}