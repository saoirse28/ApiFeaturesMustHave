{
  "ConnectionStrings": {
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=3000,syncTimeout=1000"
  },
  "Services": {
    "PaymentGateway": {
      "BaseUrl": "https://api.payment.example.com"
    },
    "Inventory": {
      "BaseUrl": "https://inventory.internal.example.com"
    },
    "Notifications": {
      "BaseUrl": "https://notifications.internal.example.com"
    }
  },
  "Resilience": {
    "Payment": {
      "MaxRetryAttempts": 3,
      "RetryDelayMs": 300,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerSamplingSeconds": 30,
      "CircuitBreakerMinThroughput": 10,
      "CircuitBreakerBreakSeconds": 30,
      "TotalTimeoutSeconds": 10,
      "AttemptTimeoutSeconds": 3
    },
    "Inventory": {
      "MaxRetryAttempts": 2,
      "RetryDelayMs": 150,
      "CircuitBreakerFailureRatio": 0.6,
      "CircuitBreakerSamplingSeconds": 20,
      "CircuitBreakerMinThroughput": 5,
      "CircuitBreakerBreakSeconds": 20,
      "TotalTimeoutSeconds": 8,
      "AttemptTimeoutSeconds": 3
    },
    "Database": {
      "MaxRetryAttempts": 2,
      "RetryDelayMs": 200,
      "TimeoutSeconds": 5,
      "FailureRatio": 0.6,
      "SamplingSeconds": 20
    },
    "Redis": {
      "MaxRetryAttempts": 2,
      "RetryDelayMs": 50,
      "TimeoutSeconds": 2,
      "FailureRatio": 0.7,
      "SamplingSeconds": 15
    }
  }
}